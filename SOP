function openDrawer(key){
  const d=SOP[key];
  if(!d)return;
  document.getElementById('d-div').textContent=d.div;
  document.getElementById('d-title').textContent=d.title;
  document.getElementById('d-purpose').textContent=d.purpose;
  const stepsEl=document.getElementById('d-steps');
  stepsEl.innerHTML=d.steps.map((s,i)=>`<div class="step-item"><div class="step-num">${i+1}</div><div class="step-text">${s}</div></div>`).join('');
  const noteEl=document.getElementById('d-note');
  if(d.note){noteEl.textContent='⚠️  '+d.note;noteEl.style.display='block';}
  else{noteEl.style.display='none';}
  document.getElementById('detail-overlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeDrawer(e){
  if(e.target===document.getElementById('detail-overlay'))closeDrawerBtn();
}
function closeDrawerBtn(){
  document.getElementById('detail-overlay').classList.remove('open');
  document.body.style.overflow='';
}

function filterSOP(q){
  if(!q.trim()){
    document.querySelectorAll('.sop-card').forEach(c=>c.style.display='');
    return;
  }
  const lq=q.toLowerCase();
  document.querySelectorAll('.sop-card').forEach(c=>{
    c.style.display=c.textContent.toLowerCase().includes(lq)?'':'none';
  });
}

document.addEventListener('keydown',e=>{if(e.key==='Escape')closeDrawerBtn();});

function scrollTo(id){
  const el=document.getElementById(id);
  if(el){el.scrollIntoView({behavior:'smooth',block:'start'});}
}
</script>
