<script>
function scrollTo(id){
  document.getElementById(id).scrollIntoView({behavior:'smooth',block:'start'});
  document.querySelectorAll('.sec-tab').forEach(t=>t.classList.remove('active'));
  const map={ops:0,sm:1,rnd:2,fin:3,hrd:4};
  document.querySelectorAll('.sec-tab')[map[id]]?.classList.add('active');
}
function scrollTo2(id){scrollTo(id)}
window.addEventListener('scroll',()=>{
  const sections=['ops','sm','rnd','fin','hrd'];
  const tabs=document.querySelectorAll('.sec-tab');
  let active=0;
  sections.forEach((id,i)=>{
    const el=document.getElementById(id);
    if(el&&el.getBoundingClientRect().top<200)active=i;
  });
  tabs.forEach(t=>t.classList.remove('active'));
  tabs[active]?.classList.add('active');
});

const SOP={
  'ops-start':{div:'Operations — Admin Ops',title:'Mulai: penerimaan pesanan masuk',purpose:'Titik masuk sistem operasional PGE. Setiap pesanan masuk dari kanal manapun harus melalui Admin Operations terlebih dahulu sebelum diproses.',steps:['Pesanan masuk dari semua kanal (marketplace, WhatsApp, B2B langsung, counter)','Admin memverifikasi kelengkapan data: nama, spesifikasi, jumlah, deadline, DP','Input ke sistem manajemen order (Notion/ClickUp)','Terbitkan Work Order resmi'],note:'Dilarang: tim Produksi tidak boleh menerima instruksi langsung dari Sales atau pelanggan. Semua harus melalui Admin Ops.'},
  'ops-order':{div:'Admin Operations — SOP Pemrosesan Pesanan',title:'Terima & verifikasi pesanan → Work Order',purpose:'Menerjemahkan pesanan Sales menjadi instruksi kerja (Work Order) yang sah untuk tim Produksi. Memastikan semua detail spesifikasi terkonfirmasi sebelum produksi dimulai.',steps:['Terima Detail Order dari divisi Sales & Marketing (custom maupun standar)','Verifikasi data: ketersediaan desain ACC, deadline, dan instruksi khusus pelanggan','Terbitkan Work Order (WO) resmi berisi spesifikasi produksi dan tenggat waktu','Teruskan WO kepada Kepala Produksi untuk Production Planning','Catat data penjualan dan rekap harian untuk Finance']},
  'ops-wo':{div:'Admin Operations',title:'Work Order (WO) — dokumen produksi resmi',purpose:'Work Order adalah dokumen resmi yang menjadi dasar seluruh aktivitas produksi. Tanpa WO yang sah, produksi tidak boleh dimulai.',steps:['WO memuat: nomor order, nama pemesan, spesifikasi produk, jumlah, deadline pengiriman','WO dilampiri blueprint dari RnD (untuk pesanan custom)','WO ditandatangani Admin Ops sebelum diserahkan ke Kepala Produksi','Salinan WO disimpan oleh Admin, Kepala Produksi, dan Finance'],note:'SOP kritis: produksi tanpa WO adalah pelanggaran prosedur.'},
  'ops-planning':{div:'Operations — Kepala Produksi',title:'Perencanaan produksi (Production Planning)',purpose:'Menjamin jadwal produksi yang akurat dan mencegah overload kapasitas. Kepala Produksi mengelola seluruh resource planning berdasarkan WO yang diterima dari Admin Ops.',steps:['Terima Work Order dari Admin Operations dan baca spesifikasi dengan teliti','Cek ketersediaan bahan baku ke Gudang & Sourcing','Lakukan capacity mapping: hitung kapasitas mesin dan operator yang tersedia','Susun jadwal produksi mingguan dan target harian per operator','Assign PIC untuk setiap stasiun kerja','Update jadwal di platform terpusat (Notion/ClickUp) agar Sales bisa pantau progress','Lakukan revisi jadwal jika ada kendala teknis atau lonjakan order mendadak']},
  'ops-bahan':{div:'Operasional — Gudang & Sourcing',title:'Cek bahan baku & capacity mapping',purpose:'Memastikan bahan baku tersedia sesuai kebutuhan WO sebelum produksi dimulai. Mencegah stock-out di tengah proses produksi.',steps:['Terima daftar kebutuhan bahan dari Admin Ops berdasarkan WO','Cek stok fisik dan sistem inventori secara bersamaan','Jika stok cukup: siapkan bahan dan serahkan ke area produksi','Jika stok kurang: buat Purchase Request dan koordinasi dengan Kepala Gudang','Verifikasi kualitas bahan sebelum diserahkan ke operator','Catat pengeluaran bahan di sistem untuk rekap Finance']},
  'ops-jadwal':{div:'Operasional — Kepala Produksi',title:'Jadwal & PIC — instruksi kerja',purpose:'Menerbitkan jadwal produksi final dan menetapkan penanggung jawab di setiap stasiun kerja. Lakukan briefing pagi setiap hari sebelum produksi dimulai.',steps:['Tetapkan urutan proses: cutting bahan → cutting gambar → jahit → trimming → QC','Assign PIC (Person In Charge) untuk setiap stasiun','Tetapkan target harian per operator sesuai kapasitas optimal','Distribusikan instruksi kerja (WO + blueprint) kepada seluruh operator','Lakukan briefing pagi: pastikan semua PIC memahami target dan spesifikasi hari ini','Update progress di platform manajemen proyek secara harian']},
  'ops-preprod':{div:'Operasional — Operator Produksi',title:'Pre-production — persiapan sebelum mulai',purpose:'Memastikan operator, mesin, dan bahan siap sebelum eksekusi produksi dimulai. Mencegah gangguan di tengah proses kerja.',steps:['Terima dan baca detail Work Order dan blueprint RnD','Pastikan memahami spesifikasi produk: ukuran, motif, bahan, teknik sebelum memulai','Ambil bahan baku yang diperlukan sesuai WO — jika kurang, lapor ke atasan','Cek kondisi fisik mesin: bersih dari sisa produksi sebelumnya','Lakukan warming-up mesin jika diperlukan sesuai prosedur standar']},
  'ops-cutting-bahan':{div:'Operasional — Operator Produksi',title:'Cutting bahan — presisi ukuran',purpose:'Pemotongan bahan baku sesuai pola dan ukuran yang ditetapkan dalam blueprint RnD. Presisi di tahap ini menentukan kualitas produk akhir.',steps:['Ambil bahan baku yang sudah disiapkan Gudang sesuai WO','Baca pola dan ukuran dari blueprint RnD dengan teliti','Lakukan pemotongan menggunakan alat yang sesuai (mesin cutting / gunting pola)','Cek presisi ukuran setelah pemotongan — toleransi sesuai standar QC','Pisahkan potongan ke area selanjutnya (cutting gambar)','First-line QC: jika ada bahan yang rusak atau tidak sesuai ukuran, pisahkan ke wadah reject'],note:'Tidak boleh membuang sisa bahan sebelum dicek oleh Kepala Produksi.'},
  'ops-cutting-gambar':{div:'Operasional — Operator Produksi',title:'Cutting gambar — cetak & motif',purpose:'Proses cetak dan pemotongan motif/gambar yang akan diterapkan ke bahan. Termasuk setting mesin cetak dan verifikasi warna.',steps:['Load file desain dari blueprint RnD ke mesin cetak/sublimasi','Lakukan test print kecil untuk verifikasi warna dan ketajaman motif','Jalankan proses cetak sesuai spesifikasi (suhu, tekanan, waktu press)','Potong gambar/motif sesuai ukuran yang ditentukan','Cek ketajaman warna, kebersihan tepi, dan kesesuaian motif dengan preview','Pisahkan hasil cetakan yang tidak sesuai ke wadah reject']},
  'ops-jahit':{div:'Operasional — Operator Produksi',title:'Jahit / rakit — kuat & rapi',purpose:'Proses penggabungan komponen menjadi produk jadi. Kualitas jahitan langsung menentukan daya tahan produk dan kepuasan pelanggan.',steps:['Gabungkan komponen bahan dan gambar/motif sesuai urutan blueprint','Jahit menggunakan mesin dengan benang warna sesuai spesifikasi','Pastikan kerapian sambungan — tidak boleh ada benang terurai','Cek simetri dan proporsi produk setelah jahit','Pasang aksesoris (resleting, kancing, label merek) jika diperlukan','Pisahkan produk yang jahitannya tidak rapi ke wadah rework'],note:'Dilarang improvisasi metode jahit tanpa izin Supervisor.'},
  'ops-trimming':{div:'Operasional — Operator / Helper Produksi',title:'Trimming & finishing',purpose:'Pembersihan akhir produk sebelum masuk QC. Tahap ini menentukan tampilan estetis produk yang diterima pelanggan.',steps:['Potong semua sisa benang (thread trimming) dengan gunting khusus trimmer','Bersihkan sisa tinta atau kotoran dari permukaan produk','Rapikan tepi jahitan yang tidak rata','Periksa kelengkapan aksesoris dan label','Lakukan quick check: apakah ada jahitan yang loncat atau robekan kain?','Barang OK → langsung ke QC. Barang cacat → ke keranjang Revisi']},
  'ops-qc':{div:'Operasional — Staff QC & Assurance',title:'Quality Control — inspeksi berlapis',purpose:'Menjamin seluruh barang yang dikirim ke konsumen memenuhi standar kualitas perusahaan. QC adalah benteng terakhir sebelum produk keluar.',steps:['Terima batch produk jadi dari tim Produksi beserta Work Order','Bandingkan produk fisik dengan blueprint RnD: ukuran, motif, warna, material','Periksa kekuatan jahitan: tarik uji ringan di setiap sambungan','Cek kebersihan cetak: tidak ada noda, luntur, atau motif tidak sesuai','Beri label "Lolos QC" pada produk yang lulus inspeksi','Pisahkan produk tidak lolos ke area rework dengan catatan cacat spesifik','Catat setiap jenis cacat di Buku Log Cacat Produksi untuk data CI']},
  'ops-dec-qc':{div:'Operasional — QC',title:'Decision: Lolos QC?',purpose:'Titik keputusan kritis. Produk yang tidak memenuhi standar TIDAK boleh lanjut ke Gudang atau pelanggan.',steps:['Lolos (YA): labeli produk dan teruskan ke Gudang & Packaging','Tidak lolos (TIDAK): berikan catatan cacat spesifik, kembalikan ke operator untuk rework','Cacat yang bisa diperbaiki → rework. Cacat yang tidak bisa diperbaiki → reject final','Laporkan jumlah lolos dan reject ke Admin Ops untuk sinkronisasi data stok'],note:'Kompromi kualitas di tahap ini berdampak langsung pada reputasi PGE.'},
  'ops-barangjadi':{div:'Operasional — Gudang',title:'Barang jadi — lolos QC',purpose:'Produk yang telah lolos QC dinyatakan sebagai barang jadi dan siap masuk gudang untuk packaging dan pengiriman.',steps:['Terima produk lolos QC beserta dokumen WO dari Staff QC','Catat jumlah barang jadi di sistem inventori gudang','Cocokkan jumlah fisik dengan target WO — laporkan jika ada selisih','Teruskan ke area packaging untuk dikemas sesuai standar'],note:'Barang jadi yang belum dikemas harus disimpan di area bersih dan tertata.'},
  'ops-gudang':{div:'Operasional — Gudang & Sourcing',title:'Manajemen Gudang & Sourcing',purpose:'Menjamin ketersediaan bahan baku untuk produksi, menjaga akurasi stok barang, dan memastikan produk jadi terorganisir dengan baik.',steps:['SOURCING: Terima kebutuhan bahan dari Admin Ops, survei dan pesan ke supplier','INBOUND: Verifikasi kualitas dan kuantitas bahan saat barang tiba','INVENTORY: Catat keluar-masuk barang real-time, lakukan stock opname berkala','Beri notifikasi ke Admin Ops jika stok bahan mencapai Reorder Point','WAREHOUSING: Terima produk lolos QC, kelompokkan berdasarkan nama pemesan/tanggal kirim','Serahkan ke Staff Logistik sesuai daftar pengiriman harian']},
  'ops-logistik':{div:'Operasional — Logistik & Pengemasan',title:'Pengemasan & Pengiriman (Logistik)',purpose:'Memastikan produk dikemas dengan standar keamanan tertinggi dan sampai di tangan konsumen selamat, tepat waktu, terdokumentasi.',steps:['Ambil produk jadi dari area Siap Kirim di Gudang','Verifikasi akhir: jumlah dan jenis produk sesuai packing list','Kemas produk: bubble wrap, box kardus, atau polymailer sesuai tingkat kerapuhan','Tempel label pengiriman (alamat, nomor resi, "Fragile" jika perlu)','Booking pickup kurir melalui sistem/aplikasi sesuai jadwal','Pastikan kurir memindai paket atau menandatangani manifest saat pickup','Pantau tracking minimal 2x sehari — eskalasi jika status tidak bergerak']},
  'ops-ci':{div:'Operasional — Kepala Produksi',title:'Continuous Improvement (CI)',purpose:'Mengaudit kinerja lini produksi secara mingguan untuk meningkatkan efisiensi dan menekan HPP.',steps:['Analisis mingguan: defect rate, cycle time, efektivitas jam kerja mesin','Identifikasi bottleneck yang menyebabkan proses melambat','Rumuskan usulan perbaikan alur kerja ke Manajemen','Uji coba metode baru dalam skala kecil terlebih dahulu','Jika terbukti efisien, terapkan ke dalam SOP standar','Update SOP dan sosialisasikan kepada seluruh tim produksi']},
  'ops-maintenance':{div:'Operasional — Kepala Produksi',title:'Perawatan mesin (Preventive Maintenance)',purpose:'Memastikan ketersediaan mesin dan meminimalkan downtime di tengah produksi yang padat.',steps:['Susun kalender perawatan preventif untuk setiap mesin produksi','Awasi pelaksanaan pembersihan dan pelumasan mesin oleh operator sesuai jadwal','Panggil teknisi untuk servis berkala atau perbaikan kerusakan fungsi','Dokumentasikan setiap riwayat servis di buku catatan aset','Operator wajib isi Form Laporan Kerusakan jika mesin berperilaku aneh'],note:'Operator: sebelum menyalakan mesin setiap hari, lakukan pengecekan singkat kondisi fisik.'},

  'sm-riset':{div:'Sales & Marketing — Kepala S&M',title:'Riset pasar & analisis tren',purpose:'Menjamin produk yang dikembangkan relevan dengan tren dan kebutuhan pasar terkini.',steps:['Pantau tren motif dan ilustrasi yang sedang happening di media sosial','Kumpulkan data kebutuhan konsumen: survei, feedback, dan analisis pesaing','Identifikasi produk best-seller sebagai bahan evaluasi RnD','Susun laporan tren sebagai input formal ke Kepala RnD','Validasi temuan riset dengan data digital (traffic, conversion rate, CPL)']},
  'sm-kampanye':{div:'Sales & Marketing — Kepala S&M',title:'SOP Manajemen Sales & Marketing',purpose:'Mengarahkan seluruh kegiatan riset, promosi, dan penjualan untuk mencapai target omzet sekaligus memastikan sinkronisasi ke Operasional.',steps:['STRATEGI: Pimpin riset kebutuhan konsumen dan feed-back loop ke RnD','KAMPANYE: Tinjau content plan, awasi performa Meta/Google Ads dan SEO','SINKRONISASI ke PRODUKSI: Setelah closing, pastikan spesifikasi diteruskan ke Ops secara akurat','KAPASITAS: Koordinasi rutin dengan Supervisor Ops terkait kapasitas mesin sebelum ambil order besar','EVALUASI: Monitor KPI individu tim, susun laporan kinerja berkala ke Manajemen']},
  'sm-konten':{div:'Marketing — Staff Marketing',title:'SOP Divisi Marketing — Konten & Etalase Digital',purpose:'Membangun brand awareness, mengakuisisi leads melalui etalase digital, dan menyediakan data riset pasar untuk RnD dan Sales.',steps:['Susun Content Calendar mingguan selaras dengan produk yang dipromosikan','Produksi materi visual (foto/video/artikel) yang mengkomunikasikan value produk','Upload konten ke medsos secara berkala, lakukan optimasi SEO website','Monitor respons audiens (like/comment/share) untuk evaluasi konten','Pantau komentar dan DM — respons profesional dalam 2 jam kerja']},
  'sm-iklan':{div:'Marketing — Staff Marketing',title:'Iklan berbayar & kampanye',purpose:'Mendongkrak visibilitas produk dan mendatangkan leads baru secara terukur dengan ROI yang positif.',steps:['Jalankan iklan Meta Ads/Google Ads sesuai profil target pasar','Rancang promo tematik musiman (Hari Raya, Promo Akhir Tahun) dengan target visibilitas','Koordinasikan konsep stan dan materi promosi untuk pameran/event','Analisis ROAS setelah periode kampanye untuk evaluasi efektivitas','Laporkan hasil kampanye ke Kepala S&M']},
  'sm-leads':{div:'Marketing → Sales',title:'Hand-off leads ke tim Sales',purpose:'Memastikan setiap leads yang dihasilkan marketing tidak hilang dan segera dieksekusi Sales.',steps:['Pastikan landing page dan form online terhubung ke database/CRM Sales','Verifikasi data prospek yang masuk secara harian','Alirkan data prospek real-time kepada Sales untuk segera dihubungi','Minta update status leads dari Sales (hot vs cold) untuk perbaiki strategi targeting']},
  'sm-b2b':{div:'Sales — Staff Sales',title:'SOP Sales — Penawaran B2B & Business Development',purpose:'Mengkonversi prospek menjadi penjualan nyata dan menjaga hubungan kemitraan jangka panjang.',steps:['Pastikan katalog dan simulasi harga grosir selalu up-to-date','Lakukan riset profil perusahaan target sebelum menghubungi (HRD/Purchasing/Marketing)','Kirimkan proposal bisnis: spesifikasi produk, lead time, dan penawaran harga','Catat setiap sampel produk yang keluar dalam logbook dengan tanggal kembali','Lakukan follow-up dalam 2x24 jam setelah sampel diterima klien']},
  'sm-spek':{div:'Sales — Staff Sales',title:'Klarifikasi spesifikasi pesanan',purpose:'Sebelum closing, wajib mengonfirmasi semua detail agar tidak ada kesalahan produksi.',steps:['Konfirmasi: Desain, Ukuran, Bahan, Warna, Jumlah, dan Deadline','Tanya: custom atau template yang sudah ada?','Konfirmasi ulang via chat/email agar ada bukti tertulis','Pastikan DP sudah lunas sebelum meneruskan form ke Admin Ops']},
  'sm-closing':{div:'Sales → Admin Ops',title:'Closing & sinkronisasi ke Admin Ops',purpose:'Langkah paling kritis: data spesifikasi yang benar dan lengkap menentukan keberhasilan seluruh proses produksi.',steps:['Isi Form Spesifikasi Pesanan secara lengkap setelah terjadi kesepakatan','Kirim Form ke Admin Operations sebagai bahan pembuatan Work Order','DILARANG: memberikan instruksi produksi langsung ke tim Produksi atau Operator','Pantau status DP sebelum meneruskan form ke Admin Ops'],note:'Critical step: kesalahan data di sini = produk salah = kerugian perusahaan.'},
  'sm-monitor':{div:'Sales — Staff Sales',title:'Monitor status order & update klien',purpose:'Menjaga kepuasan pelanggan dengan memberikan informasi terkini tentang status pesanan mereka.',steps:['Tanyakan update progress produksi ke Admin Ops setiap 1-2 hari','Informasikan status secara berkala kepada klien agar mereka merasa tenang','Jika ada potensi keterlambatan, informasikan ke klien LEBIH AWAL dengan solusi alternatif','Tangani komplain produk: dokumentasikan (foto/video), koordinasikan dengan QC/Ops']},
  'sm-aftersales':{div:'Sales — Staff Sales',title:'After sales & repeat order',purpose:'Menjaga kepuasan pelanggan pasca-transaksi dan mendorong loyalitas serta pemesanan ulang.',steps:['Konfirmasi penerimaan barang dengan pelanggan','Minta feedback atau ulasan dari pelanggan','Catat data pelanggan untuk program loyalitas dan repeat order','Hubungi kembali klien B2B 3 bulan sekali untuk tawarkan produk baru atau promo khusus','Susun laporan mingguan: tren permintaan, alasan penolakan, masukan pelanggan']},
  'sm-sync-ops':{div:'Sales & Marketing → Operasional',title:'Sinkronisasi ke Operasional',purpose:'Memastikan data spesifikasi dari Sales diteruskan dengan akurat ke Operasional untuk perencanaan produksi.',steps:['Kepala S&M memastikan semua data closing sudah diterima Admin Ops','Konfirmasi kapasitas produksi dengan Supervisor Ops sebelum commit ke klien','Koordinasikan deadline order dengan jadwal produksi yang tersedia','Update status order di sistem agar semua divisi bisa pantau']},
  'sm-evaluasi':{div:'Sales & Marketing',title:'Evaluasi & riset pasar (loop)',purpose:'Menghasilkan data untuk perbaikan produk (RnD) dan efisiensi operasional secara berkelanjutan.',steps:['Rancang kuesioner untuk memvalidasi parameter pembelian dan sensitivitas harga','Susun laporan tren dan hasil riset','Serahkan laporan ke Kepala RnD sebagai dasar pengembangan produk baru','Analisis metrik digital: traffic, conversion rate, CPL','Laporan bulanan ke Manajemen, Sales, dan RnD']},

  'rnd-brief':{div:'R&D — Kepala R&D',title:'Terima brief tren pasar dari Sales',purpose:'Memastikan setiap motif dan produk baru memiliki nilai jual tinggi berdasarkan data tren aktual dari tim Sales & Marketing.',steps:['Terima laporan tren pasar dari Kepala Sales & Marketing','Analisis data: motif/ilustrasi apa yang sedang viral, segmen pasar mana yang tumbuh','Identifikasi gap produk: apa yang belum ada di katalog tapi banyak diminta','Buat rangkuman untuk dijadikan dasar creative briefing ke Product Development']},
  'rnd-creative':{div:'R&D — Kepala R&D',title:'Creative briefing ke Product Development',purpose:'Memberikan arahan kreatif yang jelas kepada tim Product Development agar desain yang dihasilkan relevan dan on-brand.',steps:['Sampaikan brief: target motif, gaya visual, segmen pasar, dan spesifikasi produk','Tentukan timeline iterasi dan kapan batas ACC Design','Jelaskan parameter kualitas cetak yang harus dipenuhi','Tetapkan target HPP awal sebagai batas atas biaya produksi baru']},
  'rnd-desain':{div:'R&D — Product Development',title:'SOP Product Development — Desain & Eksplorasi',purpose:'Menciptakan identitas visual produk (DNA produk) yang autentik, versatile, dan siap produksi.',steps:['Terima data riset tren dari Marketing sebagai dasar pengembangan','Lakukan eksplorasi desain, termasuk kolaborasi dengan AI Generatif untuk brainstorming motif','Rancang konsep produk yang versatile (satuan maupun partai besar)','Eksekusi desain ilustrasi motif yang autentik dan eksklusif untuk PGE','Ajukan draf desain ke Kepala RnD untuk review pertama']},
  'rnd-review':{div:'R&D — Product Development',title:'Review & iterasi desain',purpose:'Memastikan desain yang dibuat feasible (bisa diproduksi) sebelum masuk ke tahap teknis. Loop ini bisa terjadi beberapa kali.',steps:['Presentasikan draf desain ke Kepala RnD untuk ditinjau','Terima feedback: apakah dari sisi estetika, teknis produksi, atau kesesuaian pasar','Lakukan revisi secara cepat berdasarkan catatan review','Ajukan ulang sampai mendapatkan status ACC Design','Desain dilarang diserahkan ke Technical Specialist sebelum status ACC']},
  'rnd-acc':{div:'R&D — Kepala R&D & Ops',title:'Decision: ACC Design?',purpose:'Titik keputusan kritis: apakah desain sudah layak estetis DAN bisa diproduksi oleh mesin yang ada.',steps:['Kepala RnD dan Kepala Produksi melakukan forum diskusi bersama','Pertanyaan kunci: "Apakah desain ini bisa dieksekusi oleh mesin yang kita miliki?"','ACC (YA): hasil didokumentasikan dalam berita acara, tim Ops mulai setup mesin','Revisi (TIDAK): Technical Specialist memberikan catatan teknis tertulis mengapa sulit diproduksi'],note:'ACC Design adalah satu-satunya pintu masuk ke tahap produksi massal.'},
  'rnd-material':{div:'R&D — Technical & Blueprint Specialist',title:'Uji material & durability test',purpose:'Memastikan material aman dan produk memiliki standar kualitas (durability) yang tinggi sebelum diproduksi massal.',steps:['Uji fisik bahan baku baru terhadap mesin cetak/potong: catat reaksi material','Tes Luntur: cuci produk purwarupa beberapa kali, cek perubahan warna','Tes Gores & Kelupas: untuk media keras/tumbler','Tes Kekuatan Jahitan/Rakit: tarik uji kekuatan sambungan','Dokumentasikan di Formulir Uji Kelayakan Bahan','Jika gagal: material tidak layak, ganti dengan alternatif yang lebih sesuai']},
  'rnd-hpp':{div:'R&D — Technical & Blueprint Specialist',title:'Optimasi HPP & formula biaya',purpose:'Memastikan profitabilitas produk terjaga melalui efisiensi material tanpa menurunkan kualitas.',steps:['Hitung konsumsi material per produk secara detail','Eksplorasi material alternatif atau metode kerja baru yang tidak menurunkan kualitas','Hitung perbandingan biaya: apakah metode baru lebih efisien?','Susun laporan struktur biaya (HPP) produk baru','Ajukan ke Kepala RnD untuk persetujuan profitabilitas sebelum lanjut ke tech pack'],note:'Target: HPP harus memberikan margin profit minimal sesuai ketentuan Manajemen.'},
  'rnd-techpack':{div:'R&D — Technical & Blueprint Specialist',title:'SOP R&D QC & Standarisasi — Tech Pack',purpose:'Menyusun blueprint yang lengkap dan presisi agar tim Operasional bisa memproduksi tanpa salah tafsir.',steps:['Terima file mentah desain dari Product Development setelah status ACC','Evaluasi teknis: "Apakah desain ini efisien secara mesin?"','Susun Tech Pack: panduan ukuran presisi (cm/mm), kode warna (CMYK/Pantone)','Sertakan: jenis bahan, teknik jahit/rakit, instruksi khusus, dan toleransi cacat','Dapatkan tanda tangan pengesahan dari Kepala RnD','Upload ke platform kolaborasi (Notion/ClickUp) agar semua pihak bisa akses']},
  'rnd-transfer':{div:'R&D → Operasional',title:'Rapat transfer teknologi ke Operasional',purpose:'Memastikan instruksi teknis (Tech Pack) dipahami dan bisa dijalankan dengan benar oleh tim Operasional.',steps:['Kepala RnD memimpin rapat serah terima dengan Supervisor Operations dan Finance','Jelaskan poin-poin krusial dalam blueprint agar tidak ada salah tafsir di lantai produksi','Bahas: estimasi HPP dan implikasinya terhadap harga jual (melibatkan Finance)','Dokumentasikan hasil rapat dalam berita acara sebagai acuan produksi']},
  'rnd-supervisi':{div:'R&D — Technical Specialist',title:'Supervisi batch pertama',purpose:'Memastikan instruksi tech pack bisa dieksekusi dengan benar pada batch produksi pertama.',steps:['Hadir di lantai produksi saat batch pertama (trial run) dimulai','Amati operator: apakah tech pack mudah dipahami dan diikuti?','Cross-check hasil produksi batch pertama dengan standar blueprint','Jika ada deviasi: segera lakukan penyesuaian instruksi kerja di tempat','Dokumentasikan temuan dan update tech pack jika diperlukan']},
  'rnd-katalog':{div:'R&D → Sales & Marketing',title:'Katalog visual — hand-over ke Sales',purpose:'Mendistribusikan aset desain ke Marketing untuk digunakan sebagai alat bantu penjualan.',steps:['Kumpulkan semua desain yang sudah ACC ke dalam katalog visual','Produksi foto dan video produk sampel untuk keperluan promosi digital','Serahkan aset visual berkualitas tinggi ke tim Marketing & Sales','Pastikan file yang diserahkan sudah bersih dan siap digunakan']},

  'fin-kas':{div:'Finance — Staff Finance & Treasury',title:'SOP Finance & Treasury — Manajemen Arus Kas',purpose:'Menjaga kesehatan arus kas perusahaan dan memastikan setiap rupiah yang masuk-keluar tercatat akurat.',steps:['Terima laporan transaksi harian dari Admin Ops (penjualan) dan tim Sourcing (pengeluaran)','Lakukan rekonsiliasi: cocokkan saldo buku dengan mutasi bank/kas fisik setiap akhir hari','Laporkan status dana operasional setiap pagi ke Manajer','Susun laporan posisi kas harian yang transparan']},
  'fin-piutang':{div:'Finance — Staff Finance & Treasury',title:'Piutang B2B & Utang Vendor',purpose:'Memastikan Term of Payment dipatuhi klien dan jadwal pembayaran vendor strategis.',steps:['PIUTANG: Masukkan setiap transaksi kredit klien B2B ke sistem monitoring piutang','Kirim invoice tepat setelah barang terkirim beserta bukti surat jalan dari Logistik','Hubungi klien 3-5 hari sebelum jatuh tempo sebagai friendly reminder','Eskalasi ke Sales jika jatuh tempo terlewati','VENDOR: Cocokkan invoice vendor dengan data barang masuk dari Gudang','Susun jadwal pembayaran berdasarkan prioritas jatuh tempo dan urgensi suplai']},
  'fin-payroll':{div:'Finance — Staff Finance & Treasury',title:'Penggajian (Payroll & Incentive)',purpose:'Memastikan hak finansial karyawan (gaji, lembur, bonus) didistribusikan akurat dan tepat waktu.',steps:['Terima data kehadiran dan update status karyawan dari HRGA','Koordinasikan dengan Kepala S&M untuk data bonus/insentif tim Sales','Hitung gaji pokok, tunjangan, lembur, bonus, dan potongan pajak/BPJS','Ajukan draf payroll ke Manajer untuk verifikasi','Transfer gaji sesuai jadwal penggajian yang ditetapkan']},
  'fin-hpp':{div:'Finance — Staff Accounting & Tax',title:'SOP Accounting — Kalkulasi HPP & Skema Harga',purpose:'Menghasilkan struktur biaya yang akurat sebagai dasar penentuan harga jual yang kompetitif namun menguntungkan.',steps:['Kumpulkan data biaya bahan baku (Gudang), biaya TK (HRGA), dan penyusutan mesin (Ops)','Hitung total biaya produksi per unit secara periodik','Berkolaborasi dengan Manajemen untuk tentukan markup yang sesuai','Pertimbangkan harga pasar dari Sales dan batas bawah harga grosir','Sahkan skema harga jual dalam sistem sebagai acuan Sales']},
  'fin-anggaran':{div:'Finance — Staff Accounting & Tax',title:'Penganggaran & monitoring plafon',purpose:'Mengendalikan pengeluaran operasional agar tetap dalam plafon yang disetujui.',steps:['Kumpulkan usulan kebutuhan biaya dari semua divisi di awal periode','Catat setiap realisasi pengeluaran dan bandingkan dengan anggaran (budget vs actual)','Berikan warning tertulis ke Kepala Divisi jika pengeluaran hampir mencapai plafon','Gunakan data penjualan historis untuk prediksi arus kas dan kebutuhan modal mendatang']},
  'fin-pajak':{div:'Finance — Staff Accounting & Tax',title:'Kepatuhan pajak — PPh & PPN',purpose:'Memenuhi kewajiban perpajakan perusahaan sesuai regulasi hukum Indonesia untuk menghindari denda.',steps:['Pastikan setiap transaksi yang mengandung unsur pajak teridentifikasi (PPN masukan/keluaran, PPh)','Hitung pajak bulanan dan tahunan secara akurat sesuai ketentuan','Lakukan penyetoran dan pelaporan via DJP online tepat waktu','Simpan bukti potong, faktur pajak, dan SPT dengan rapi untuk keperluan audit'],note:'Batas waktu pelaporan pajak tidak bisa mundur. Denda administrasi sangat merugikan.'},
  'fin-audit':{div:'Finance — Audit Internal',title:'Audit internal & kontrol anggaran',purpose:'Memastikan tidak ada kebocoran dana dan anggaran digunakan sesuai rencana.',steps:['Pantau batas pengeluaran operasional per divisi','Lakukan cross-check antara nota fisik, laporan pengadaan, dan kas riil','Identifikasi pemborosan, anomali, atau selisih dana','Laporkan temuan signifikan kepada Manajer beserta rekomendasi tindakan korektif']},
  'fin-laporan':{div:'Finance — Pelaporan',title:'Laporan keuangan — L/R, Neraca, Arus Kas',purpose:'Menyediakan laporan keuangan yang valid bagi manajemen untuk pengambilan keputusan strategis.',steps:['Lakukan closing pembukuan setiap akhir bulan','Susun Laporan Laba Rugi, Neraca, dan Arus Kas','Analisis kinerja: produk dengan profit tertinggi vs terendah','Identifikasi area operasional yang mengalami pemborosan (waste bahan baku tinggi)','Susun presentasi analisis data untuk Manajer dengan rekomendasi taktis']},
  'fin-analisis':{div:'Finance',title:'Analisis kinerja & forecasting',purpose:'Memberikan rekomendasi strategis kepada Manajemen terkait arah kesehatan finansial perusahaan.',steps:['Sajikan data profitabilitas: produk/lini mana yang paling dan paling kurang menguntungkan','Buat prediksi tren pendapatan berdasarkan data historis','Susun budgeting untuk periode mendatang','Rekomendasikan: produk mana yang perlu dikembangkan atau dihentikan']},

