<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PGE — Aligning Organizations System</title>
<style>
:root {
  --bg: #0d0e12;
  --bg2: #13151c;
  --bg3: #1a1d27;
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.14);
  --text: #e8e6de;
  --muted: #8a8880;
  --hint: #5a5856;

  --purple: #7f77dd;
  --purple-bg: rgba(127,119,221,0.1);
  --purple-border: rgba(127,119,221,0.3);

  --teal: #1d9e75;
  --teal-bg: rgba(29,158,117,0.1);
  --teal-border: rgba(29,158,117,0.3);

  --blue: #378add;
  --blue-bg: rgba(55,138,221,0.1);
  --blue-border: rgba(55,138,221,0.3);

  --amber: #ef9f27;
  --amber-bg: rgba(239,159,39,0.1);
  --amber-border: rgba(239,159,39,0.3);

  --green: #639922;
  --green-bg: rgba(99,153,34,0.1);
  --green-border: rgba(99,153,34,0.3);

  --coral: #d85a30;
  --coral-bg: rgba(216,90,48,0.1);
  --coral-border: rgba(216,90,48,0.3);

  --pink: #d4537e;
  --pink-bg: rgba(212,83,126,0.1);
  --pink-border: rgba(212,83,126,0.3);

  --red: #e24b4a;
  --red-bg: rgba(226,75,74,0.08);
  --red-border: rgba(226,75,74,0.3);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;font-size:15px;line-height:1.6}
a{color:var(--blue);text-decoration:none}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(13,14,18,0.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);height:56px;display:flex;align-items:center;padding:0 24px;gap:0;justify-content:space-between}
.nav-brand{display:flex;align-items:center;gap:10px}
.nav-logo{width:28px;height:28px;background:var(--purple);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;letter-spacing:-.5px}
.nav-name{font-weight:600;font-size:14px;letter-spacing:.02em}
.nav-sub{font-size:11px;color:var(--muted);margin-left:4px}
.nav-links{display:flex;gap:4px}
.nav-link{padding:5px 12px;border-radius:6px;font-size:13px;color:var(--muted);cursor:pointer;transition:all .15s;border:none;background:none}
.nav-link:hover,.nav-link.active{background:var(--bg3);color:var(--text)}
.nav-search{display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:5px 12px;font-size:13px;color:var(--muted)}
.nav-search input{background:none;border:none;outline:none;color:var(--text);font-size:13px;width:180px}
.nav-search input::placeholder{color:var(--hint)}

/* HERO */
.hero{margin-top:56px;padding:80px 24px 60px;text-align:center;border-bottom:1px solid var(--border);position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:300px;background:radial-gradient(ellipse at center,rgba(127,119,221,0.12) 0%,transparent 70%);pointer-events:none}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:var(--purple-bg);border:1px solid var(--purple-border);border-radius:20px;padding:4px 12px;font-size:11px;color:var(--purple);font-weight:500;letter-spacing:.06em;text-transform:uppercase;margin-bottom:20px}
.hero h1{font-size:48px;font-weight:700;letter-spacing:-.03em;line-height:1.1;margin-bottom:12px}
.hero h1 span{color:var(--purple)}
.hero p{font-size:17px;color:var(--muted);max-width:520px;margin:0 auto 32px;line-height:1.6}
.hero-stats{display:flex;justify-content:center;gap:32px;flex-wrap:wrap}
.hero-stat{text-align:center}
.hero-stat .n{font-size:28px;font-weight:700;color:var(--text)}
.hero-stat .l{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:2px}

/* SECTION TABS */
.section-nav{position:sticky;top:56px;z-index:90;background:var(--bg);border-bottom:1px solid var(--border);padding:0 24px;display:flex;gap:0;overflow-x:auto}
.section-nav::-webkit-scrollbar{display:none}
.sec-tab{padding:14px 18px;font-size:13px;font-weight:500;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .15s;border-radius:0}
.sec-tab:hover{color:var(--text)}
.sec-tab.active{color:var(--text);border-bottom-color:var(--purple)}

/* MAIN */
main{max-width:1200px;margin:0 auto;padding:0 24px 80px}

/* SECTION */
.sop-section{padding:48px 0 0;border-bottom:1px solid var(--border)}
.sop-section:last-child{border-bottom:none}
.sec-header{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:32px}
.sec-title{display:flex;align-items:center;gap:12px}
.sec-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px}
.sec-name{font-size:22px;font-weight:700;letter-spacing:-.02em}
.sec-sub{font-size:13px;color:var(--muted);margin-top:2px}
.sec-badge{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:3px 8px;font-size:11px;color:var(--muted);white-space:nowrap}

/* FLOW CARD */
.flow-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:20px}
.flow-card-header{padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.flow-card-title{font-size:14px;font-weight:600}
.flow-card-meta{font-size:11px;color:var(--muted)}
.flow-hint{font-size:11px;color:var(--hint);display:flex;align-items:center;gap:5px}

/* SVG FLOW */
.flow-svg-wrap{overflow-x:auto;padding:20px}
.flow-svg-wrap::-webkit-scrollbar{height:4px}
.flow-svg-wrap::-webkit-scrollbar-track{background:var(--bg3)}
.flow-svg-wrap::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.flow-svg-wrap svg{min-width:600px}

/* SVG NODES */
.fnode{cursor:pointer;transition:opacity .15s}
.fnode:hover{opacity:.85}
.fnode rect,.fnode polygon,.fnode ellipse{transition:filter .15s}
.fnode:hover rect,.fnode:hover polygon,.fnode:hover ellipse{filter:brightness(1.15)}

/* DETAIL PANEL */
.detail-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.5);backdrop-filter:blur(4px)}
.detail-overlay.open{display:block}
.detail-drawer{position:fixed;right:0;top:0;bottom:0;width:420px;max-width:100vw;background:var(--bg2);border-left:1px solid var(--border2);z-index:201;overflow-y:auto;transform:translateX(100%);transition:transform .25s cubic-bezier(.4,0,.2,1)}
.detail-overlay.open .detail-drawer{transform:translateX(0)}
.drawer-header{padding:20px 20px 16px;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--bg2);z-index:1}
.drawer-close{float:right;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:4px 10px;color:var(--muted);cursor:pointer;font-size:13px;transition:all .15s}
.drawer-close:hover{color:var(--text);border-color:var(--border2)}
.drawer-div{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.drawer-title{font-size:16px;font-weight:700;color:var(--text);padding-right:60px}
.drawer-purpose{margin:0 20px 16px;padding:12px 14px;background:var(--bg3);border-radius:8px;font-size:12px;color:var(--muted);line-height:1.6;border-left:3px solid var(--purple)}
.drawer-steps{padding:0 20px 24px}
.drawer-steps-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:12px}
.step-item{display:flex;gap:12px;align-items:flex-start;margin-bottom:10px}
.step-num{width:22px;height:22px;border-radius:50%;background:var(--bg3);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--muted);flex-shrink:0;margin-top:1px}
.step-text{font-size:13px;color:var(--text);line-height:1.5}
.drawer-note{margin:0 20px 20px;padding:10px 14px;background:var(--amber-bg);border:1px solid var(--amber-border);border-radius:8px;font-size:12px;color:var(--amber);line-height:1.5}

/* SOP GRID */
.sop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;margin-bottom:32px}
.sop-card{background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:16px;cursor:pointer;transition:all .15s}
.sop-card:hover{border-color:var(--border2);background:var(--bg2)}
.sop-card-header{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.sop-card-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.sop-card-title{font-size:13px;font-weight:600;line-height:1.3}
.sop-card-role{font-size:11px;color:var(--muted);margin-bottom:8px}
.sop-card-steps{font-size:11px;color:var(--hint)}

/* LEGEND */
.legend-row{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:24px}
.leg{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted)}
.leg-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.leg-diamond{width:10px;height:10px;background:var(--amber-bg);border:1px solid var(--amber-border);transform:rotate(45deg);flex-shrink:0}

/* RESPONSIVE */
@media(max-width:700px){
  .hero h1{font-size:32px}
  .nav-links{display:none}
  .detail-drawer{width:100vw}
  .sec-header{flex-direction:column}
}
</style>
</head>
